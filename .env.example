# Copy to .env for local dev, or set these in the Catalyst console
# (Project Settings → Environment Variables) for the scrape-job Function
# and the ui AppSail service.

# Cliq notification — Incoming Webhook (recommended).
# Generate in Cliq: channel → Integrations → Incoming Webhooks → copy URL.
CLIQ_WEBHOOK_URL=

# If you use the REST API URL instead of an incoming webhook, also set
# a Zoho OAuth token — the notifier will send it as a Bearer header.
# CLIQ_OAUTH_TOKEN=
